# =============================================
# Advaya Environment Variables (Fully Decentralized)
# Copy this file to .env.local in apps/web/ and fill in the values
# =============================================

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
# Network: 'testnet' for development, 'mainnet' for production
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint (leave blank to use public testnet default)
# NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract ID of the deployed Advaya Soroban contract
# Deploy with: stellar contract deploy --wasm contracts/advaya/target/wasm32-unknown-unknown/release/advaya.wasm
# Leave blank to use local-only (localStorage) state without on-chain persistence
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Get a free JWT at https://app.pinata.cloud → API Keys
# Without this, files are stored in-memory only (lost on page refresh)
NEXT_PUBLIC_PINATA_JWT=

# Your Pinata dedicated gateway (or use the public gateway below)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── No backend required ──────────────────────────────────────────────────────
# The Node.js backend (/backend) is deprecated and no longer used.
# All data flows through:
#   Identity & State  → Stellar Soroban smart contract (on-chain)
#   Messaging         → Waku P2P network (decentralized)
#   File storage      → IPFS + Pinata (decentralized)
#
# The following are kept for local dev reference only:
# PORT=4000
# DATABASE_URL=postgresql://advaya:advaya_secret@localhost:5432/advaya
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=change_me_to_a_random_64_char_string
