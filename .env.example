# =============================================
# Advaya Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# Backend
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://advaya:advaya_secret@localhost:5432/advaya

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate a strong random secret)
JWT_SECRET=change_me_to_a_random_64_char_string

# Stellar Network (testnet for development)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Phase 3: IPFS/Pinata (not needed for Phase 1)
# PINATA_API_KEY=
# PINATA_SECRET_KEY=
# PINATA_JWT=
